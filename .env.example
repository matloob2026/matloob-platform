# =====================================================================
# Matloob — Environment Variables
# Copy to .env.local (gitignored) and fill in real values.
# NOTE: no country/currency values belong here — those are DB-driven
# (see prisma/schema.prisma Country/Currency tables + docs/LOCALIZATION.md)
# =====================================================================

# --- Database -----------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/matloob?schema=public"

# --- Auth (NextAuth.js) ---------------------------------------------
# On Vercel, set this to your actual deployment URL (e.g.
# https://your-project.vercel.app or your custom domain) — NOT
# localhost. Used for the email verification/password reset links
# AuthService sends. NextAuth's own OAuth callback/redirect handling
# uses `trustHost: true` (src/auth/auth.config.ts) and derives the
# correct host from the actual incoming request instead of this
# variable, so a stale value here won't cause OAuth redirects to break
# — but it will still send email links to the wrong host, so keep it
# current.
NEXTAUTH_URL="http://localhost:3000"
# Required. Generate with: openssl rand -base64 32
# src/auth/auth.config.ts accepts either NEXTAUTH_SECRET (this
# project's documented name) or AUTH_SECRET (NextAuth v5's own
# auto-detected name) — set at least one of the two on your host, or
# NextAuth throws "MissingSecret".
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Both required together to enable Google sign-in — see
# src/auth/auth.config.ts (the provider is only registered when both
# are set, so leaving these blank just means the Google button on
# /login and /register surfaces NextAuth's normal "provider not
# configured" behavior, nothing breaks). Get these from Google Cloud
# Console > APIs & Services > Credentials > OAuth 2.0 Client ID (type:
# Web application). Authorized redirect URI must be:
#   <NEXTAUTH_URL>/api/auth/callback/google
# e.g. https://your-project.vercel.app/api/auth/callback/google
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# --- Media storage (Cloudinary) --------------------------------------
# All three required together — see src/lib/cloudinary.ts. Without
# them, image upload (request galleries, profile avatars) returns a
# clear "not configured" error rather than crashing; nothing else in
# the app depends on these being set.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Transactional email (Resend) -----------------------------------
# Both required together to send real emails — see
# src/lib/mailer/index.ts. Without these, the app falls back to
# ConsoleMailer (dev-only: logs the email instead of sending it).
# RESEND_FROM_EMAIL must be an address on a domain verified with Resend.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Matloob <noreply@yourdomain.com>"

# --- Other transactional channels (SMS, used by NotificationService) -
SMS_PROVIDER_API_KEY=""

# --- Observability ---------------------------------------------------
SENTRY_DSN=""

# --- Feature flags (mirrors SiteSetting group="feature_flags";
#     env vars here are BUILD-TIME fallbacks only — the source of
#     truth at runtime is always the database) --------------------
NEXT_PUBLIC_ENABLE_AI_ASSISTANT="false"
