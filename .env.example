# =====================================================================
# Matloob — Environment Variables
# Copy to .env.local (gitignored) and fill in real values.
# NOTE: no country/currency values belong here — those are DB-driven
# (see prisma/schema.prisma Country/Currency tables + docs/LOCALIZATION.md)
# =====================================================================

# --- Database -----------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/matloob?schema=public"

# --- Auth (NextAuth.js) ---------------------------------------------
# On Vercel, set this to your actual deployment URL (e.g.
# https://your-project.vercel.app or your custom domain) — NOT
# localhost. Required for correct callback/redirect URLs and for the
# email verification/password reset links AuthService sends.
NEXTAUTH_URL="http://localhost:3000"
# Required. Generate with: openssl rand -base64 32
# src/auth/auth.config.ts accepts either NEXTAUTH_SECRET (this
# project's documented name) or AUTH_SECRET (NextAuth v5's own
# auto-detected name) — set at least one of the two on your host, or
# NextAuth throws "MissingSecret".
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# --- Media storage (choose one provider, e.g. S3-compatible) -------
MEDIA_STORAGE_PROVIDER="s3" # "s3" | "cloudinary" | "local" (dev only)
S3_BUCKET_NAME=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- Transactional email/SMS (used by NotificationService) ---------
EMAIL_PROVIDER_API_KEY=""
SMS_PROVIDER_API_KEY=""

# --- Observability ---------------------------------------------------
SENTRY_DSN=""

# --- Feature flags (mirrors SiteSetting group="feature_flags";
#     env vars here are BUILD-TIME fallbacks only — the source of
#     truth at runtime is always the database) --------------------
NEXT_PUBLIC_ENABLE_AI_ASSISTANT="false"
